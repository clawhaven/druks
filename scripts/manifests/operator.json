{
  "name": "__NAME__",
  "description": "Druks operator — pushes branches, opens PRs, posts agent comments.",
  "url": "__PUBLIC_URL__",
  "redirect_url": "__PUBLIC_URL__/apps/callback",
  "public": false,
  "hook_attributes": {
    "url": "__PUBLIC_URL__/_external/github/events/",
    "active": true
  },
  "default_events": [
    "pull_request",
    "pull_request_review",
    "push"
  ],
  "default_permissions": {
    "metadata": "read",
    "contents": "write",
    "pull_requests": "write",
    "issues": "write",
    "checks": "read",
    "statuses": "read"
  }
}

[project]
name = "druks-{{ name }}"
version = "0.1.0"
description = "{{ Name }} extension for druks."
requires-python = ">=3.11"
dependencies = ["druks"]

[dependency-groups]
dev = [
    "pytest>=8.4.0",
    "pytest-asyncio>=1.3.0",
]

# Local checkout of druks core; point at the published package once one exists.
[tool.uv.sources]
druks = { path = "{{ druks_path }}", editable = true }

# The platform discovers this extension here — installing the package is the
# whole registration.
[project.entry-points."druks.extensions"]
{{ name }} = "druks_{{ name }}.extension:{{ Name }}"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.pytest.ini_options]
# Everything in druks is async; without this, an async test fails confusingly.
asyncio_mode = "auto"
